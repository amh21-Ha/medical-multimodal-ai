APP_NAME=multimodal-medical-ai
APP_ENV=dev
LOG_LEVEL=INFO
API_PREFIX=/api/v1
API_KEY=change-me
ALLOW_API_KEY_FALLBACK=true
AUTH_MODE=hybrid
JWT_SECRET_KEY=replace-this-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=multimodal-medical-ai
JWT_AUDIENCE=multimodal-medical-ai-users

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@postgres:5432/multimodal
JOB_REPOSITORY_BACKEND=postgres
MLFLOW_TRACKING_URI=http://mlflow:5000
STORAGE_ROOT=./storage
MAX_UPLOAD_MB=512
